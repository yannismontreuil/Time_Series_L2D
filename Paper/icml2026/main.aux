\newlabel{fig:exp_synthetic_transfer_regime_estimation_appendix}{{3}{26}{Regime-0 expert dependence in the synthetic transfer experiment. Each heatmap shows the pairwise Pearson correlation (color: \([-1,1]\)) between experts' per-round losses (experts indexed \(0\)--\(3\)). Top row: partial feedback (only queried losses observed). Columns (left-to-right) show the ground-truth correlation implied by the simulator and the correlations estimated by each method. L2D-SLDS best recovers the block-structured correlations (experts \(\{0,1\}\) vs.\ \(\{2,3\}\)), highlighting the benefit of modeling shared latent factors for cross-expert information transfer under censoring.\relax }{figure.caption.8}{}}
\newlabel{fig:exp_synthetic_transfer_regime_estimation_appendix@cref}{{[figure][3][2147483647]3}{[1][26][]26}}
